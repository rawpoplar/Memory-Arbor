{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "--experimental-strip-types",
              "${CLAUDE_PLUGIN_ROOT}/scripts/memory-arbor-prompt-frame.mjs",
              "--format=claude-json"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
